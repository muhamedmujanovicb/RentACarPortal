@model IEnumerable<RentACarPortal.Models.Vehicle>

@{
	ViewData["Title"] = "Corporate Fleet";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h1 class="display-5 fw-bold text-dark">Fleet Management Operations</h1>
            <p class="text-muted mb-0">Internal live overview of active agency assets and rental states.</p>
        </div>
        <button class="btn btn-primary btn-lg shadow-sm">+ Add New Vehicle</button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>License Plate</th>
                        <th>Vehicle Specifications</th>
                        <th>Year</th>
                        <th>Daily Rate</th>
                        <th>Insurance</th>
                        <th class="pe-4">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var car in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted fw-bold">#@car.Id</td>
                            <td><code class="text-uppercase bg-light px-2 py-1 border rounded text-dark">@car.RegisterNumberOfVehicle</code></td>
                            <td>
                                <span class="fs-5 fw-semibold text-dark">@car.Make</span>
                                <span class="text-secondary fs-5">@car.Model</span>
                            </td>
                            <td>@car.Year</td>
                            <td class="fw-bold text-success">$@car.DailyRate.ToString("F2")</td>
                            <td>
                                <span class="badge @(car.HasInsurance ? "bg-info text-dark" : "bg-secondary")">
                                    @(car.HasInsurance ? "Fully Insured" : "No Insurance")
                                </span>
                            </td>
                            <td class="pe-4">
                                <span class="badge rounded-pill px-3 py-2 @(car.Status == "Available" ? "bg-success" : car.Status == "Rented" ? "bg-danger" : "bg-warning text-dark")">
                                    @car.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
