@model IEnumerable<RentACarPortal.Models.Vehicle>
@{
    ViewData["Title"] = "Booking Fleet";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Select Vehicle — FleetDrive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet" asp-append-version="true">
</head>
<body class="dashboard-body">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="index.html">
                <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
                <span class="brand-text">FleetDrive</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="dashboard.html">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="fleet-overview.html">Fleet Overview</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="booking-companies.html">Booking Companies</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="contract-history.html">Contract History</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <span class="dashboard-user d-none d-md-inline">
                        <i class="bi bi-person-circle me-1"></i> @(ViewBag.Username ?? "Admin")
                    </span>
                    <a href="login.html" class="btn btn-outline-primary btn-sm px-4">Log Out</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="dashboard-page">
        <div class="container">

            <!-- Breadcrumb / Header / Missing href-->
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="BookingCompanies" asp-controller="UserDashboard" asp-route-loggedInUser="@ViewBag.Username" class="text-decoration-none">Partner Network</a></li>
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none">@ViewBag.SelectedCompany</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Select Vehicle</li>
                </ol>
            </nav>

            <header class="dashboard-header mb-4">
                <div>
                    <span class="section-label">New Booking</span>
                    <h1 class="dashboard-title">Available Fleet</h1>
                    <p class="dashboard-subtitle">Select an available vehicle from the inventory to proceed with the reservation.</p>
                </div>
                <div class="dashboard-header-badge">
                    <i class="bi bi-car-front"></i>
                </div>
            </header>

            <!-- Filters (Optional UI enhancement) -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; border: 1px solid var(--border) !important;">
                <div class="card-body p-3 d-flex flex-wrap gap-2 align-items-center">
                    <span class="text-muted small fw-medium me-2"><i class="bi bi-funnel me-1"></i> Filter by:</span>
                    <select class="form-select form-select-sm w-auto border-light-subtle bg-light">
                        <option selected>All Categories</option>
                        <option value="1">Economy</option>
                        <option value="2">Sedan</option>
                        <option value="3">SUV</option>
                        <option value="4">Luxury</option>
                    </select>
                    <select class="form-select form-select-sm w-auto border-light-subtle bg-light">
                        <option selected>Transmission</option>
                        <option value="1">Automatic</option>
                        <option value="2">Manual</option>
                    </select>
                </div>
            </div>

            <!-- Fleet Grid -->
            <div class="row g-4">

                @if (Model != null && Model.Any())
                {
                    @foreach (var vehicle in Model)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="vehicle-card">
                                <div class="vehicle-img-placeholder">
                                    <i class="bi bi-car-front-fill"></i>
                                    <span class="vehicle-badge">@vehicle.Status</span>
                                </div>
                                <div class="vehicle-details">
                                    <h3 class="vehicle-title">@vehicle.Make @vehicle.Model</h3>
                                    <div class="vehicle-type">@vehicle.TypeOfVehicle</div>

                                    <div class="vehicle-specs">
                                        <div class="spec-item"><i class="bi bi-palette"></i> @vehicle.DriveTerrain</div>
                                        <div class="spec-item"><i class="bi bi-calendar"></i> @vehicle.Year</div>
                                        <div class="spec-item"><i class="bi bi-card-text"></i> @vehicle.BootSpace</div>
                                    </div>

                                    <div class="vehicle-footer">
                                        <div class="vehicle-price">
                                            €@vehicle.DailyRate<span>/day</span>
                                        </div>
                                        <a href="@Url.Action("BookingContractRequest", "BookingContractRequest", new { loggedInUser = ViewBag.Username, selectedCompany = ViewBag.SelectedCompany, vehicleId = vehicle.Id })" class="btn btn-primary btn-sm px-4">Book Now</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-warning text-center">No available vehicles found for this company at the moment.</div>
                    </div>
                }

            </div>

        </div>
    </main>

    <!-- Footer -->
    <footer class="footer py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="footer-brand"><i class="bi bi-car-front-fill me-2"></i>FleetDrive</span>
                    <span class="text-muted ms-2">&copy; 2026 FleetDrive. All rights reserved.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="footer-link me-3">Privacy Policy</a>
                    <a href="#" class="footer-link me-3">Terms of Service</a>
                    <a href="#" class="footer-link">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

