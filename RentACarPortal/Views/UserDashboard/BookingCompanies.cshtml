@model IEnumerable<RentACarPortal.Models.User>
@{
    ViewData["Title"] = "Booking Companies";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking Companies — FleetDrive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet" asp-append-version="true">
</head>
<body class="dashboard-body">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="index.html">
                <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
                <span class="brand-text">FleetDrive</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="dashboard.html">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="fleet-overview.html">Fleet Overview</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="booking-companies.html">Booking Companies</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="contract-history.html">Contract History</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <span class="dashboard-user d-none d-md-inline">
                        <i class="bi bi-person-circle me-1"></i> @(ViewBag.Username ?? "Admin")
                    </span>
                    <a href="login.html" class="btn btn-outline-primary btn-sm px-4">Log Out</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="dashboard-page">
        <div class="container">

            <!-- Header -->
            <header class="dashboard-header">
                <div>
                    <span class="section-label">Partner Network</span>
                    <h1 class="dashboard-title">Booking Companies</h1>
                    <p class="dashboard-subtitle">Select an active partner company to manage their bookings and fleet allocations.</p>
                </div>
                <div class="dashboard-header-badge">
                    <i class="bi bi-buildings"></i>
                </div>
            </header>

            <!-- Companies Grid -->
            <div class="row g-4">

                @if (Model != null)
                {
                    @foreach (var company in Model)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <a href="@Url.Action("BookingFleet", "BookingFleet", new { loggedInUser = ViewBag.Username, companyName = company.Username })" class="dashboard-card">
                                <div class="dashboard-card-icon icon-fleet">
                                    <i class="bi bi-building"></i>
                                </div>
                                <div class="dashboard-card-content d-flex flex-column justify-content-center h-100">
                                    <h3 class="mb-1">@company.Username</h3>
                                    <p class="mb-0">
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-pill">
                                            <i class="bi bi-record-circle-fill small me-1"></i> Active Partner
                                        </span>
                                    </p>
                                </div>
                                <div class="dashboard-card-arrow">
                                    <i class="bi bi-chevron-right"></i>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-warning">No booking companies found or database context is missing.</div>
                    </div>
                }

            </div>

        </div>
    </main>

    <!-- Footer -->
    <footer class="footer py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="footer-brand"><i class="bi bi-car-front-fill me-2"></i>FleetDrive</span>
                    <span class="text-muted ms-2">&copy; 2026 FleetDrive. All rights reserved.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="footer-link me-3">Privacy Policy</a>
                    <a href="#" class="footer-link me-3">Terms of Service</a>
                    <a href="#" class="footer-link">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
