@{
    ViewData["Title"] = "Booking Contract Request";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking Contract Request</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"> 
    <link href="~/css/styles.css" rel="stylesheet" asp-append-version="true">
</head>
<body class="dashboard-body">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg bg-white sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="#">
                <div class="brand-icon"><i class="fas fa-car"></i></div>
                Portal
            </a>
            <button class="navbar-toggler" type="submit" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link active" href="#">Contracts</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Fleet</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="dashboard-page">
        <div class="container" style="max-width: 900px;">
            
            <!-- Dashboard Header -->
            <div class="dashboard-header">
                <div>
                    <span class="section-label">Administration</span>
                    <h1 class="dashboard-title">Contract Request</h1>
                    <p class="dashboard-subtitle">Fill in the required information to generate and send a booking contract request.</p>
                </div>
                <div class="dashboard-header-badge">
                    <i class="fas fa-file-signature"></i>
                </div>
            </div>

            <!-- Form -->
            <form action="/Contracts/SubmitRequest" method="POST">
                
                <!-- Section 1: Driver Information -->
                <div class="form-section-card">
                    <div class="form-section-header">
                        <div class="form-section-icon icon-user-detail">
                            <i class="fas fa-id-card"></i>
                        </div>
                        <div>
                            <h2>Driver Information</h2>
                            <p>Personal and identification details of the primary driver.</p>
                        </div>
                    </div>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label for="DriverFullName" class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="DriverFullName" name="DriverFullName" placeholder="e.g. John Doe" required>
                        </div>
                        <div class="col-md-6">
                            <label for="DateOfBirth" class="form-label">Date of Birth</label>
                            <input type="date" class="form-control" id="DateOfBirth" name="DateOfBirth" required>
                        </div>
                        <div class="col-md-6">
                            <label for="PersonalIdNumber" class="form-label">Personal ID Number</label>
                            <input type="text" class="form-control" id="PersonalIdNumber" name="PersonalIdNumber" placeholder="Enter ID number" required>
                        </div>
                        <div class="col-md-6">
                            <label for="Telephone" class="form-label">Telephone</label>
                            <input type="tel" class="form-control" id="Telephone" name="Telephone" placeholder="+1 (555) 000-0000" required>
                        </div>
                        <div class="col-12">
                            <label for="Address" class="form-label">Residential Address</label>
                            <input type="text" class="form-control" id="Address" name="Address" placeholder="Full street address, city, zip code" required>
                        </div>
                        <div class="col-md-6">
                            <label for="DrivingLicenseNumber" class="form-label">Driving License Number</label>
                            <input type="text" class="form-control" id="DrivingLicenseNumber" name="DrivingLicenseNumber" placeholder="License #" required>
                        </div>
                        <div class="col-md-6">
                            <label for="PassportNumber" class="form-label">Passport Number</label>
                            <input type="text" class="form-control" id="PassportNumber" name="PassportNumber" placeholder="Passport #" required>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Rental Information -->
                <div class="form-section-card">
                    <div class="form-section-header">
                        <div class="form-section-icon icon-rental-detail">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div>
                            <h2>Rental Details</h2>
                            <p>Specify the location and date for the contract issuance.</p>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label for="PlaceOfIssue" class="form-label">Place of Issue (Rental City)</label>
                            <input type="text" class="form-control" id="PlaceOfIssue" name="PlaceOfIssue" placeholder="e.g. New York, NY" required>
                        </div>
                        <div class="col-md-6">
                            <label for="DateOfIssue" class="form-label">Date of Issue (Rental Date)</label>
                            <input type="date" class="form-control" id="DateOfIssue" name="DateOfIssue" required>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Notes -->
                <div class="form-section-card">
                    <div class="form-section-header">
                        <div class="form-section-icon icon-notes-detail">
                            <i class="fas fa-clipboard-list"></i>
                        </div>
                        <div>
                            <h2>Notes & Reminders</h2>
                            <p>Any additional information or special requests for the admin.</p>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-12">
                            <label for="Notes" class="form-label">Additional Notes</label>
                            <textarea class="form-control" id="Notes" name="Notes" placeholder="Type any reminders, specific vehicle requests, or extra equipment needs here..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="recommendor-actions">
                    <button type="submit" class="btn btn-primary btn-recommend">
                        <i class="fas fa-paper-plane me-2"></i> Send Contract Request
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
