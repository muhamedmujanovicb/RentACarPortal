@model IEnumerable<RentACarPortal.Models.Vehicle>

@{
	ViewData["Title"] = "Corporate Fleet";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FleetDrive — Premium Car Rental</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/Home/Index">
                <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
                <span class="brand-text">FleetDrive</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" href="#">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#overview">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="/Login/LoginForm" class="btn btn-outline-primary btn-sm px-4">Log In</a>
                    <a href="/SignUp/SignUpForm" class="btn btn-primary btn-sm px-4">Sign Up</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <header class="hero-section">
        <div class="container">
            <div class="row align-items-center min-vh-100 py-5">
                <div class="col-lg-6">
                    <span class="badge hero-badge mb-3">Trusted since 2010</span>
                    <h1 class="hero-title mb-4">Drive more.<br>Worry less.</h1>
                    <p class="hero-subtitle mb-4">
                        FleetDrive delivers reliable, affordable car rentals for business travelers,
                        families, and everyday adventures. Your journey starts here.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="#overview" class="btn btn-primary btn-lg px-4">Learn More</a>
                        <a href="#" class="btn btn-outline-light btn-lg px-4">Browse Fleet</a>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block">
                    <div class="hero-image-wrapper">
                        <div class="hero-image-placeholder">
                            <i class="bi bi-car-front"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Company Overview -->
    <section id="overview" class="overview-section py-5">
        <div class="container py-4">
            <div class="text-center mb-5">
                <span class="section-label">Company Overview</span>
                <h2 class="section-title mt-2">Built for every kind of journey</h2>
                <p class="section-subtitle mx-auto">
                    FleetDrive is a full-service car rental company with a modern fleet, transparent pricing,
                    and customer-first support. We make renting a car simple, safe, and stress-free.
                </p>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="overview-card h-100">
                        <div class="overview-icon">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h5>Reliable Fleet</h5>
                        <p class="text-muted mb-0">
                            Every vehicle is inspected, sanitized, and maintained to the highest standards
                            before it reaches your hands.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="overview-card h-100">
                        <div class="overview-icon">
                            <i class="bi bi-tag"></i>
                        </div>
                        <h5>Transparent Pricing</h5>
                        <p class="text-muted mb-0">
                            No hidden fees. Clear daily rates, flexible packages, and competitive prices
                            for short and long-term rentals.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="overview-card h-100">
                        <div class="overview-icon">
                            <i class="bi bi-headset"></i>
                        </div>
                        <h5>24/7 Support</h5>
                        <p class="text-muted mb-0">
                            Our team is available around the clock to assist with bookings, roadside help,
                            and any questions you may have.
                        </p>
                    </div>
                </div>
            </div>

            <div class="row g-4 align-items-center overview-stats">
                <div class="col-lg-6">
                    <h3 class="mb-3">Who we are</h3>
                    <p class="text-muted">
                        Founded with a simple mission — to give people freedom on the road — FleetDrive has
                        grown into one of the region's most trusted rental providers. From compact city cars
                        to spacious SUVs and premium sedans, we offer options for every need and budget.
                    </p>
                    <p class="text-muted mb-4">
                        Whether you're picking up at the airport, renting for a weekend getaway, or managing
                        a corporate fleet account, our streamlined booking process and dedicated account
                        managers ensure a seamless experience from start to finish.
                    </p>
                    <ul class="overview-list">
                        <li><i class="bi bi-check-circle-fill"></i> 50+ locations nationwide</li>
                        <li><i class="bi bi-check-circle-fill"></i> 2,000+ vehicles in our fleet</li>
                        <li><i class="bi bi-check-circle-fill"></i> 98% customer satisfaction rate</li>
                        <li><i class="bi bi-check-circle-fill"></i> Free cancellation up to 24 hours</li>
                    </ul>
                </div>
                <div class="col-lg-6">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="stat-card text-center">
                                <div class="stat-number">15+</div>
                                <div class="stat-label">Years of Service</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-card text-center">
                                <div class="stat-number">2K+</div>
                                <div class="stat-label">Vehicles Available</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-card text-center">
                                <div class="stat-number">50+</div>
                                <div class="stat-label">Pickup Locations</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-card text-center">
                                <div class="stat-number">100K+</div>
                                <div class="stat-label">Happy Customers</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer py-4">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="footer-brand"><i class="bi bi-car-front-fill me-2"></i>FleetDrive</span>
                    <span class="text-muted ms-2">&copy; 2026 FleetDrive. All rights reserved.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="footer-link me-3">Privacy Policy</a>
                    <a href="#" class="footer-link me-3">Terms of Service</a>
                    <a href="#" class="footer-link">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
