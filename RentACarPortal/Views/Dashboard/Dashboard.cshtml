@{
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Control Dashboard — FleetDrive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet">
</head>
<body class="dashboard-body">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="index.html">
                <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
                <span class="brand-text">FleetDrive</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" href="dashboard.html">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Index">Home</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <span class="dashboard-user d-none d-md-inline">
                        <i class="bi bi-person-circle me-1"></i> @(ViewBag.Username ?? "Admin")
                    </span>
                    <a href="/Login/LoginForm" class="btn btn-outline-primary btn-sm px-4">Log Out</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Dashboard -->
    <main class="dashboard-page">
        <div class="container">

            <header class="dashboard-header">
                <div>
                    <span class="section-label">Control Panel</span>
                    <h1 class="dashboard-title">Dashboard</h1>
                    <p class="dashboard-subtitle">Select a module below to manage your fleet operations.</p>
                </div>
                <div class="dashboard-header-badge">
                    <i class="bi bi-speedometer2"></i>
                </div>
            </header>

            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <a href="@Url.Action("FleetManager", "Dashboard", new { loggedInUser = ViewBag.Username })" class="dashboard-card">
                        <div class="dashboard-card-icon icon-fleet">
                            <i class="bi bi-truck"></i>
                        </div>
                        <div class="dashboard-card-content">
                            <h3>Fleet Management</h3>
                            <p>Manage vehicles, availability, maintenance, and fleet assignments.</p>
                        </div>
                        <span class="dashboard-card-arrow"><i class="bi bi-arrow-right"></i></span>
                    </a>
                </div>

                <div class="col-md-6 col-lg-4">
                    <a href="statistics.html" class="dashboard-card">
                        <div class="dashboard-card-icon icon-stats">
                            <i class="bi bi-bar-chart-line"></i>
                        </div>
                        <div class="dashboard-card-content">
                            <h3>Statistics</h3>
                            <p>View rental performance, revenue trends, and operational insights.</p>
                        </div>
                        <span class="dashboard-card-arrow"><i class="bi bi-arrow-right"></i></span>
                    </a>
                </div>

                <div class="col-md-6 col-lg-4">
                    <a href="contract-management.html" class="dashboard-card">
                        <div class="dashboard-card-icon icon-contract">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <div class="dashboard-card-content">
                            <h3>Contract Management</h3>
                            <p>Create, edit, and oversee active rental contracts and agreements.</p>
                        </div>
                        <span class="dashboard-card-arrow"><i class="bi bi-arrow-right"></i></span>
                    </a>
                </div>

                <div class="row g-4">
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Action("FleetOverview", "Dashboard", new { loggedInUser = ViewBag.Username })" class="dashboard-card">
                            <div class="dashboard-card-icon icon-overview">
                                <i class="bi bi-grid"></i>
                            </div>
                            <div class="dashboard-card-content">
                                <h3>Fleet Overview</h3>
                                <p>Get a comprehensive, high-level view of all vehicles and their current statuses.</p>
                            </div>
                            <span class="dashboard-card-arrow"><i class="bi bi-arrow-right"></i></span>
                        </a>
                    </div>

                <div class="col-md-6 col-lg-4">
                    <a href="contract-history.html" class="dashboard-card">
                        <div class="dashboard-card-icon icon-history">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div class="dashboard-card-content">
                            <h3>Contract History</h3>
                            <p>Browse completed and archived contracts with full audit trails.</p>
                        </div>
                        <span class="dashboard-card-arrow"><i class="bi bi-arrow-right"></i></span>
                    </a>
                </div>
            </div>

        </div>
    </main>

    <footer class="footer py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="footer-brand"><i class="bi bi-car-front-fill me-2"></i>FleetDrive</span>
                    <span class="text-muted ms-2">&copy; 2026 FleetDrive. All rights reserved.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="footer-link me-3">Privacy Policy</a>
                    <a href="#" class="footer-link me-3">Terms of Service</a>
                    <a href="#" class="footer-link">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>