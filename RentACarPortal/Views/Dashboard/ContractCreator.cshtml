@model RentACarPortal.Models.Contract
@{
    ViewData["Title"] = "ContractCreator";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contract Creator — FleetDrive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet">
</head>
<body class="dashboard-body">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="index.html">
                <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
                <span class="brand-text">FleetDrive</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="dashboard.html">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="contract-creator.html">Create Contract</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="index.html">Home</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <span class="dashboard-user d-none d-md-inline">
                        <i class="bi bi-person-circle me-1"></i> @(ViewBag.Username ?? "Admin")
                    </span>
                    <a href="login.html" class="btn btn-outline-primary btn-sm px-4">Log Out</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Contract Creator -->
    <main class="dashboard-page">
        <div class="container">

            <header class="dashboard-header">
                <div>
                    <span class="section-label">Contract Management</span>
                    <h1 class="dashboard-title">Create Rental Contract</h1>
                    <p class="dashboard-subtitle">Fill in the details below to generate a new vehicle rental agreement.</p>
                </div>
                <div class="dashboard-header-badge">
                    <i class="bi bi-file-earmark-plus"></i>
                </div>
            </header>

            <form class="recommendor-form" asp-controller="ContractCreator" asp-action="NewContract" method="post">
                <input type="hidden" name="loggedInUser" value="@ViewBag.Username" />

                <!-- Vehicle Details -->
                <div class="form-section-card mb-4">
                    <div class="form-section-header">
                        <div class="form-section-icon icon-fleet">
                            <i class="bi bi-car-front"></i>
                        </div>
                        <div>
                            <h2>Vehicle Information</h2>
                            <p>Details regarding the rented vehicle and station</p>
                        </div>
                    </div>
                    <div class="form-section-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label for="RentalStation" class="form-label">Rental Station</label>
                                <input type="text" class="form-control" id="RentalStation" name="RentalStation" required>
                            </div>
                            <div class="col-md-4">
                                <label for="TypeOfVehicle" class="form-label">Type of Vehicle</label>
                                <select class="form-select" id="TypeOfVehicle" name="TypeOfVehicle" required>
                                    <option value="" disabled selected>Select type...</option>
                                    <option value="coupe">Coupe</option>
                                    <option value="compact">Compact</option>
                                    <option value="sedan">Sedan</option>
                                    <option value="limo">Limo</option>
                                    <option value="suv">SUV</option>
                                    <option value="jeep">Jeep</option>
                                    <option value="monovolumen">Monovolumen</option>
                                    <option value="van">Van</option>
                                    <option value="minibus">Minibus</option>
                                    <option value="bus">Bus</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label for="RegisterNumberOfVehicle" class="form-label">Register Number</label>
                                <input type="text" class="form-control" id="RegisterNumberOfVehicle" name="RegisterNumberOfVehicle" placeholder="e.g. AB-123-CD" required>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Driver Details -->
                <div class="form-section-card mb-4">
                    <div class="form-section-header">
                        <div class="form-section-icon icon-users">
                            <i class="bi bi-person-vcard"></i>
                        </div>
                        <div>
                            <h2>Driver Details</h2>
                            <p>Personal and identification information of the primary driver</p>
                        </div>
                    </div>
                    <div class="form-section-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label for="RentDriver" class="form-label">Driver Full Name</label>
                                <input type="text" class="form-control" id="RentDriver" name="RentDriver" required>
                            </div>
                            <div class="col-md-4">
                                <label for="DateOfBirth" class="form-label">Date of Birth</label>
                                <input type="date" class="form-control" id="DateOfBirth" name="DateOfBirth" required>
                            </div>
                            <div class="col-md-4">
                                <label for="PersonalNumber" class="form-label">Personal ID Number</label>
                                <input type="text" class="form-control" id="PersonalNumber" name="PersonalNumber" required>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label for="Address" class="form-label">Address</label>
                                <input type="text" class="form-control" id="Address" name="Address" required>
                            </div>
                            <div class="col-md-4">
                                <label for="Telephone" class="form-label">Telephone</label>
                                <input type="number" class="form-control" id="Telephone" name="Telephone" required>
                            </div>
                            <div class="col-md-4">
                                <label for="DrivingLicenseNumber" class="form-label">Driving License Number</label>
                                <input type="text" class="form-control" id="DrivingLicenseNumber" name="DrivingLicenseNumber" required>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label for="PassportNumber" class="form-label">Passport Number</label>
                                <input type="number" class="form-control" id="PassportNumber" name="PassportNumber" required>
                            </div>
                            <div class="col-md-4">
                                <label for="PlaceOfIssue" class="form-label">Place of Issue (Rental City)</label>
                                <input type="text" class="form-control" id="PlaceOfIssue" name="PlaceOfIssue" required>
                            </div>
                            <div class="col-md-4">
                                <label for="DateOfIssue" class="form-label">Date of Issue (Rental Date)</label>
                                <input type="date" class="form-control" id="DateOfIssue" name="DateOfIssue" required>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Rental Period -->
                <div class="form-section-card mb-4">
                    <div class="form-section-header">
                        <div class="form-section-icon icon-history">
                            <i class="bi bi-calendar-range"></i>
                        </div>
                        <div>
                            <h2>Rental Period & Location</h2>
                            <p>Pickup and return scheduling details</p>
                        </div>
                    </div>
                    <div class="form-section-body">

                        <h5 class="fs-6 fw-bold mb-3 text-primary">Pickup Details</h5>
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label for="RentalStartPlace" class="form-label">Pickup Location</label>
                                <input type="text" class="form-control" id="RentalStartPlace" name="RentalStartPlace" required>
                            </div>
                            <div class="col-md-4">
                                <label for="RentalStartDate" class="form-label">Pickup Date</label>
                                <input type="date" class="form-control" id="RentalStartDate" name="RentalStartDate" required>
                            </div>
                            <div class="col-md-4">
                                <label for="RentalStartTime" class="form-label">Pickup Time</label>
                                <input type="time" class="form-control" id="RentalStartTime" name="RentalStartTime" required>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25 mb-4">

                        <h5 class="fs-6 fw-bold mb-3 text-primary">Return Details</h5>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label for="RentalEndPlace" class="form-label">Return Location</label>
                                <input type="text" class="form-control" id="RentalEndPlace" name="RentalEndPlace" required>
                            </div>
                            <div class="col-md-4">
                                <label for="RentalEndDate" class="form-label">Return Date</label>
                                <input type="date" class="form-control" id="RentalEndDate" name="RentalEndDate" required>
                            </div>
                            <div class="col-md-4">
                                <label for="RentalEndTime" class="form-label">Return Time</label>
                                <input type="time" class="form-control" id="RentalEndTime" name="RentalEndTime" required>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Fuel & Financials -->
                <div class="form-section-card mb-4">
                    <div class="form-section-header">
                        <div class="form-section-icon icon-contract">
                            <i class="bi bi-cash-coin"></i>
                        </div>
                        <div>
                            <h2>Fuel & Financials</h2>
                            <p>Deposit, fuel tracking, and insurance options</p>
                        </div>
                    </div>
                    <div class="form-section-body">

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label for="FullTankSizeLiquid" class="form-label">Fuel Tank Capacity (L)</label>
                                <input type="number" class="form-control" id="FullTankSizeLiquid" name="FullTankSizeLiquid" min="0" required>
                            </div>
                            <div class="col-md-4">
                                <label for="FuelRecieved" class="form-label">Fuel Level at Pickup (L)</label>
                                <input type="number" class="form-control" id="FuelRecieved" name="FuelRecieved" min="0" required>
                            </div>
                            <div class="col-md-4">
                                <label for="FuelReturned" class="form-label">Fuel Level at Return (L)</label>
                                <input type="number" class="form-control" id="FuelReturned" name="FuelReturned" min="0" placeholder="Optional for pickup">
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="Deposit" class="form-label">Security Deposit Amount</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-currency-euro"></i></span>
                                    <input type="number" step="0.01" class="form-control" id="Deposit" name="Deposit" min="0" required>
                                </div>
                            </div>
                            <div class="col-md-6 d-flex align-items-end pb-2">
                                <div class="form-check form-switch p-3 border rounded bg-light w-100 mb-0 d-flex align-items-center gap-2">
                                    <input class="form-check-input ms-0 mt-0" type="checkbox" id="Insurance" name="Insurance" style="width: 2.5em; height: 1.25em;">
                                    <label class="form-check-label fw-semibold ms-2 mb-0" for="Insurance">Include Insurance Coverage</label>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Additional Notes -->
                <div class="form-section-card mb-4">
                    <div class="form-section-header">
                        <div class="form-section-icon icon-recommendor">
                            <i class="bi bi-journal-text"></i>
                        </div>
                        <div>
                            <h2>Additional Notes</h2>
                            <p>Any extra information or remarks regarding the rental</p>
                        </div>
                    </div>
                    <div class="form-section-body">
                        <div class="mb-3">
                            <label for="Comment" class="form-label">Public Comment</label>
                            <textarea class="form-control" id="Comment" name="Comment" rows="3" placeholder="Notes visible to the customer..."></textarea>
                        </div>
                        <div class="mb-0">
                            <label for="Remarks" class="form-label">Internal Remarks</label>
                            <textarea class="form-control" id="Remarks" name="Remarks" rows="2" placeholder="Private notes for staff only..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="recommendor-actions border-top mt-4 pt-4 d-flex justify-content-end gap-3">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 fw-semibold">Cancel</button>
                    <button type="submit" class="btn btn-primary px-5 py-2 fw-semibold shadow-sm">
                        <i class="bi bi-file-earmark-check me-2"></i> Create Contract
                    </button>
                </div>

            </form>

        </div>
    </main>

    <footer class="footer py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="footer-brand"><i class="bi bi-car-front-fill me-2"></i>FleetDrive</span>
                    <span class="text-muted ms-2">&copy; 2026 FleetDrive. All rights reserved.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="footer-link me-3">Privacy Policy</a>
                    <a href="#" class="footer-link me-3">Terms of Service</a>
                    <a href="#" class="footer-link">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>