@model List<RentACarPortal.Models.Vehicle>
@{
	ViewData["Title"] = "FleetOverview";
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fleet Overview — FleetDrive</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet">
</head>
<body class="dashboard-body">

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="index.html">
        <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
        <span class="brand-text">FleetDrive</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
              aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNavbar">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" href="dashboard.html">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="fleet-overview.html">Fleet Overview</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="index.html">Home</a>
          </li>
        </ul>
        <div class="d-flex align-items-center gap-3">
          <span class="dashboard-user d-none d-md-inline">
                        <i class="bi bi-person-circle me-1"></i> @(ViewBag.Username ?? "Admin")
          </span>
          <a href="login.html" class="btn btn-outline-primary btn-sm px-4">Log Out</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Fleet Overview -->
  <main class="dashboard-page">
    <div class="container">

      <header class="dashboard-header">
        <div>
          <span class="section-label text-white-50">Company Fleet</span>
          <h1 class="dashboard-title">Fleet Overview</h1>
          <p class="dashboard-subtitle">Browse and monitor all registered vehicles in your company's network.</p>
        </div>
        <div class="dashboard-header-badge">
          <i class="bi bi-grid"></i>
        </div>
      </header>

      <div class="row g-4">
                    @foreach (var vehicle in Model)
                    {
                        <div class="col-lg-6 col-xl-4">
                            <div class="form-section-card h-100 d-flex flex-column" style="padding: 1.75rem;">
                                <!-- Header -->
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h3 class="fw-bold mb-1 fs-5 text-dark">@vehicle.Make @vehicle.Model <span class="text-muted fw-normal ms-1 fs-6">@vehicle.Year</span></h3>
                                        <div class="d-flex gap-2 align-items-center mt-2">
                                            <span class="badge bg-primary text-white text-uppercase" style="letter-spacing: 0.05em;">@vehicle.TypeOfVehicle</span>
                                            <span class="badge bg-light text-dark border font-monospace">@vehicle.RegisterNumberOfVehicle</span>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <h4 class="text-primary fw-bold mb-0">€@vehicle.DailyRate</h4>
                                        <span class="text-muted small">/day</span>
                                    </div>
                                </div>

                                <hr class="text-muted opacity-25 mb-3 mt-1">

                                <!-- Specs Grid -->
                                <div class="row g-3 mb-4 flex-grow-1">
                                    <div class="col-6 d-flex align-items-center gap-2">
                                        <i class="bi bi-people text-primary fs-5"></i>
                                        <div>
                                            <div class="small fw-semibold text-dark">@vehicle.NumberOfSeats Seats</div>
                                        </div>
                                    </div>
                                    <div class="col-6 d-flex align-items-center gap-2">
                                        <i class="bi bi-fuel-pump text-primary fs-5"></i>
                                        <div>
                                            <div class="small fw-semibold text-dark">
                                            <span class="badge bg-info">
                                                @(vehicle.IsDiesel ? "Diesel" : "Petrol")
                                            </span>
                                            </div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@vehicle.FuelTankSize L Tank &bull; @(vehicle.FuelEfficiency/10) L/100km</div>
                                        </div>
                                    </div>
                                    <div class="col-6 d-flex align-items-center gap-2">
                                        <i class="bi bi-bezier2 text-primary fs-5"></i>
                                        <div>
                                            <div class="small fw-semibold text-dark">@vehicle.DriveTerrain</div>
                                        </div>
                                    </div>
                                    <div class="col-6 d-flex align-items-center gap-2">
                                        <i class="bi bi-fan text-primary fs-5"></i>
                                        <div>
                                            <div class="small fw-semibold text-dark">@vehicle.ACtype</div>
                                        </div>
                                    </div>
                                    <div class="col-6 d-flex align-items-center gap-2">
                                        <i class="bi bi-box-seam text-primary fs-5"></i>
                                        <div>
                                            <div class="small fw-semibold text-dark">@vehicle.BootSpace Boot</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Features -->
                            <div class="d-flex flex-wrap gap-2 pt-3 border-top mt-auto">
                                <span class="badge @(vehicle.HasInsurance ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") border">
                                    <i class="bi @(vehicle.HasInsurance ? "bi-shield-check" : "bi-shield-x")"></i>
                                    @(vehicle.HasInsurance ? "Insured" : "Uninsured")
                                </span>

                                <span class="badge @(vehicle.HasChildrenSafety ? "bg-primary-subtle text-primary" : "bg-light text-muted") border">
                                    <i class="bi bi-person-arms-up"></i>
                                    @(vehicle.HasChildrenSafety ? "Child Safety Ready" : "No Child Safety")
                                </span>

                                <span class="badge @(vehicle.HasNavigation ? "bg-info-subtle text-info" : "bg-light text-muted") border">
                                    <i class="bi bi-geo-alt-fill"></i>
                                    @(vehicle.HasNavigation ? "GPS Active" : "No GPS")
                                </span>
                            </div>

                            <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center">
                                <form asp-controller="FleetOverview" asp-action="DeleteVehicle" method="post" onsubmit="return confirm('Are you sure you want to delete this vehicle?');">
                                    <input type="hidden" name="id" value="@vehicle.Id" />
                                    <input type="hidden" name="loggedInUser" value="@ViewBag.Username" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                            </div>
                        </div>
                    }
                </div>
    </div>
  </main>

  <footer class="footer py-4 mt-auto">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
          <span class="footer-brand"><i class="bi bi-car-front-fill me-2"></i>FleetDrive</span>
          <span class="text-muted ms-2">&copy; 2026 FleetDrive. All rights reserved.</span>
        </div>
        <div class="col-md-6 text-center text-md-end">
          <a href="#" class="footer-link me-3">Privacy Policy</a>
          <a href="#" class="footer-link me-3">Terms of Service</a>
          <a href="#" class="footer-link">Contact Us</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
