@{
	ViewData["Title"] = "FleetManager";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FleetManager — FleetDrive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet">
</head>
<body class="dashboard-body">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="index.html">
                <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
                <span class="brand-text">FleetDrive</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="user-dashboard.html">My Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="fleet-manager.html">FleetManager</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="index.html">Home</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <span class="dashboard-user d-none d-md-inline">
                        <i class="bi bi-person-circle me-1"></i> @(ViewBag.Username ?? "Admin")
                    </span>
                    <a href="/Login/LoginForm" class="btn btn-outline-primary btn-sm px-4">Log Out</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- FleetManager Add Vehicle -->
    <main class="dashboard-page">
        <div class="container">

            <header class="dashboard-header">
                <div>
                    <span class="section-label">Fleet Management</span>
                    <h1 class="dashboard-title">Add New Vehicle</h1>
                    <p class="dashboard-subtitle">Register a new vehicle to expand your rental fleet capabilities.</p>
                </div>
                <div class="dashboard-header-badge">
                    <i class="bi bi-plus-circle"></i>
                </div>
            </header>

            <form class="recommendor-form" asp-controller="FleetManager" asp-action="NewVehicle" method="post">
                <input type="hidden" name="loggedInUser" value="@ViewBag.Username" />

                <div class="row g-4">
                    <!-- Vehicle Related Section -->
                    <div class="col-lg-8">
                        <div class="form-section-card h-100">
                            <div class="form-section-header">
                                <div class="form-section-icon icon-fleet">
                                    <i class="bi bi-car-front"></i>
                                </div>
                                <div>
                                    <h2>Vehicle Related</h2>
                                    <p>Technical specifications and features of the vehicle</p>
                                </div>
                            </div>

                            <div class="form-section-body">
                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <label for="Make" class="form-label">Make</label>
                                        <input type="text" class="form-control" id="Make" name="Make" placeholder="e.g. Toyota" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="Model" class="form-label">Model</label>
                                        <input type="text" class="form-control" id="Model" name="Model" placeholder="e.g. Corolla" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="Year" class="form-label">Year</label>
                                        <input type="number" class="form-control" id="Year" name="Year" min="1990" max="2027" placeholder="e.g. 2024" required>
                                    </div>
                                </div>

                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <label for="TypeOfVehicle" class="form-label">Vehicle Type</label>
                                        <select class="form-select" id="TypeOfVehicle" name="TypeOfVehicle" required>
                                            <option value="" disabled selected>Select type...</option>
                                            <option value="coupe">Coupe</option>
                                            <option value="compact">Compact</option>
                                            <option value="sedan">Sedan</option>
                                            <option value="limo">Limo</option>
                                            <option value="suv">SUV</option>
                                            <option value="jeep">Jeep</option>
                                            <option value="monovolumen">Monovolumen</option>
                                            <option value="van">Van</option>
                                            <option value="minibus">Minibus</option>
                                            <option value="bus">Bus</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="DriveTerrain" class="form-label">Drive Terrain</label>
                                        <select class="form-select" id="DriveTerrain" name="DriveTerrain" required>
                                            <option value="" disabled selected>Select terrain...</option>
                                            <option value="2wd">2WD</option>
                                            <option value="4wd">4WD</option>
                                            <option value="awd">AWD</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="BootSpace" class="form-label">Boot Space</label>
                                        <select class="form-select" id="BootSpace" name="BootSpace" required>
                                            <option value="" disabled selected>Select size...</option>
                                            <option value="small">Small</option>
                                            <option value="medium">Medium</option>
                                            <option value="big">Big</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <label for="NumberOfSeats" class="form-label">Number of Seats</label>
                                        <input type="number" class="form-control" id="NumberOfSeats" name="NumberOfSeats" min="1" max="60" placeholder="e.g. 5" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="FuelEfficiency" class="form-label">Fuel Efficiency (L/100km)</label>
                                        <input type="number" class="form-control" id="FuelEfficiency" name="FuelEfficiency" step="0.1" min="0" placeholder="e.g. 6.5" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="FuelTankSize" class="form-label">Fuel Tank Size (L)</label>
                                        <input type="number" class="form-control" id="FuelTankSize" name="FuelTankSize" step="1" min="0" placeholder="e.g. 50" required>
                                    </div>
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-md-12">
                                        <label class="form-label">AC Type</label>
                                        <div class="d-flex gap-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="ACtype" id="ACtype" value="single" required>
                                                <label class="form-check-label" for="ACtype">Single Zone</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="ACtype" id="ACtype" value="dual">
                                                <label class="form-check-label" for="ACtype">Dual Zone</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mb-4">

                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <select name="IsDiesel" class="form-select">
                                            <option value="true">Diesel</option>
                                            <option value="false">Petrol</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <select name="HasChildrenSafety" class="form-select">
                                                <option value="true">Has child safety features</option>
                                                <option value="false">Does not have child safety features</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <select name="HasNavigation" class="form-select">
                                                <option value="true">Has navigation</option>
                                                <option value="false">Does not have navigation</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <!-- Contract Related Section -->
                    <div class="col-lg-4">
                        <div class="form-section-card h-100">
                            <div class="form-section-header">
                                <div class="form-section-icon icon-contract">
                                    <i class="bi bi-file-earmark-text"></i>
                                </div>
                                <div>
                                    <h2>Contract Related</h2>
                                    <p>Legal and rental rate details</p>
                                </div>
                            </div>

                            <div class="form-section-body">
                                <div class="mb-4">
                                    <label for="RegisterNumberOfVehicle" class="form-label">Register Number</label>
                                    <input type="text" class="form-control" id="RegisterNumberOfVehicle" name="RegisterNumberOfVehicle" placeholder="e.g. AB-123-CD" required>
                                    <div class="form-text text-muted small mt-1">Vehicle's official license plate.</div>
                                </div>

                                <div class="mb-4">
                                    <label for="DailyRate" class="form-label">Daily Rental Rate</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-currency-euro"></i></span>
                                        <input type="number" class="form-control" id="DailyRate" name="DailyRate" min="0" step="0.01" placeholder="e.g. 45" required>
                                    </div>
                                </div>
                                
                                <div class="mb-4 pt-2">
                                    <select name="HasInsurance" class="form-select">
                                        <option value="true">Has active insurance</option>
                                        <option value="false">Does not have active insurance</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="recommendor-actions border-top mt-4 pt-4 d-flex justify-content-end gap-3">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 fw-semibold">Cancel</button>
                    <button type="submit" class="btn btn-primary px-5 py-2 fw-semibold shadow-sm">
                        <i class="bi bi-plus-lg me-2"></i> Add Vehicle to Fleet
                    </button>
                </div>

            </form>

        </div>
    </main>

    <footer class="footer py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="footer-brand"><i class="bi bi-car-front-fill me-2"></i>FleetDrive</span>
                    <span class="text-muted ms-2">&copy; 2026 FleetDrive. All rights reserved.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="footer-link me-3">Privacy Policy</a>
                    <a href="#" class="footer-link me-3">Terms of Service</a>
                    <a href="#" class="footer-link">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
