@model IEnumerable<RentACarPortal.Models.Contract>
@{
    ViewData["Title"] = "Contract History";
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contract History — FleetDrive</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet">
</head>
<body class="dashboard-body">

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="index.html">
        <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
        <span class="brand-text">FleetDrive</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
              aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNavbar">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" href="dashboard.html">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="fleet-overview.html">Fleet Overview</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="contract-creator.html">Create Contract</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="contract-history.html">Contract History</a>
          </li>
        </ul>
        <div class="d-flex align-items-center gap-3">
          <span class="dashboard-user d-none d-md-inline">
            <i class="bi bi-person-circle me-1"></i> Admin
          </span>
          <a href="login.html" class="btn btn-outline-primary btn-sm px-4">Log Out</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Contract History -->
  <main class="dashboard-page">
    <div class="container">

      <header class="dashboard-header">
        <div>
          <span class="section-label">Contract Management</span>
          <h1 class="dashboard-title">Contract History</h1>
          <p class="dashboard-subtitle">Monitor and manage active, completed, and cancelled rental agreements.</p>
        </div>
        <div class="dashboard-header-badge">
          <i class="bi bi-card-list"></i>
        </div>
      </header>

      <!-- Filters -->
      <div class="d-flex flex-wrap gap-2 mb-4">
        <button class="btn btn-primary rounded-pill px-4">All Contracts</button>
        <button class="btn btn-outline-secondary bg-white rounded-pill px-4">Active</button>
        <button class="btn btn-outline-secondary bg-white rounded-pill px-4">Completed</button>
        <button class="btn btn-outline-secondary bg-white rounded-pill px-4">Cancelled</button>
      </div>

      <div class="contract-list d-flex flex-column gap-3">

                @foreach (var contract in Model)
                {
                    <div class="form-section-card p-3 p-md-4">
                        <div class="row align-items-center text-center text-md-start gy-3">

                            <!-- Customer Name -->
                            <div class="col-12 col-md-3 d-flex align-items-center gap-3 justify-content-center justify-content-md-start">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center text-primary" style="width: 48px; height: 48px;">
                                    <i class="bi bi-person-fill fs-5"></i>
                                </div>
                                <div>
                                    <!-- Displays the Username from the linked User table -->
                                    <h5 class="mb-0 fw-bold text-dark fs-6">@contract.RentDriver</h5>
                                    <small class="text-muted">Customer</small>
                                </div>
                            </div>

                            <!-- Vehicle Type -->
                            <div class="col-6 col-md-2">
                                <span class="badge bg-primary text-white text-uppercase px-3 py-2">@contract.TypeOfVehicle</span>
                            </div>

                            <!-- Registration -->
                            <div class="col-6 col-md-2">
                                <span class="badge bg-light text-dark border font-monospace px-3 py-2">@contract.RegisterNumberOfVehicle</span>
                            </div>

                            <div class="col-12 col-md-2 text-muted d-none d-md-flex justify-content-center align-items-center">
                                <span class="opacity-50">-----------------</span>
                            </div>

                            <!-- Status -->
                            <div class="col-12 col-md-3 d-flex align-items-center justify-content-center justify-content-md-end gap-2">
                                <span class="badge @(contract.Status == "Active" ? "bg-success-subtle text-success" : (contract.Status == "Completed" ? "bg-secondary-subtle text-secondary" : "bg-danger-subtle text-danger")) border px-3 py-2 rounded-pill">
                                    @contract.Status
                                </span>

                                @if (contract.Status == "Active")
                                {
                                    <form asp-controller="ContractHistory" asp-action="UpdateStatus" method="post" class="d-flex gap-1">
                                        <input type="hidden" name="id" value="@contract.Id" />

                                        <button type="submit" name="newStatus" value="Completed" class="btn btn-sm btn-outline-success">
                                            <input type="hidden" name="loggedInUser" value="@ViewBag.Username" />
                                            <i class="bi bi-check-lg"></i>
                                        </button>

                                        <button type="submit" name="newStatus" value="Cancelled" class="btn btn-sm btn-outline-danger">
                                            <input type="hidden" name="loggedInUser" value="@ViewBag.Username" />
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
    </div>
  </main>

  <footer class="footer py-4 mt-auto">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
          <span class="footer-brand"><i class="bi bi-car-front-fill me-2"></i>FleetDrive</span>
          <span class="text-muted ms-2">&copy; 2026 FleetDrive. All rights reserved.</span>
        </div>
        <div class="col-md-6 text-center text-md-end">
          <a href="#" class="footer-link me-3">Privacy Policy</a>
          <a href="#" class="footer-link me-3">Terms of Service</a>
          <a href="#" class="footer-link">Contact Us</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
